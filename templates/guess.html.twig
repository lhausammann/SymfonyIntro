{% extends 'base.html.twig' %}

{% block body %}
    <h1>Willkommen zu Spiel #{{ game.id }}</h1>
    <h2>Wähle eine Nummer:</h2>
    <form name="guess" method="post">
        <input type="number" name="number" min="1" max="100" required>
        <button type="submit">Raten</button>
    </form>
    {% if result %}
        <h3>{{ guess }} {{ result }} ausgedachte Zahl</h3>

    {% endif %}
{% endblock %}
